# Template — copy to `.dev.vars` for local Wrangler dev,
# and set the real values in Cloudflare Pages → Settings → Variables and Secrets.
#
# Never commit `.dev.vars` or `.env` — both are gitignored.

# Admin panel password (visit /admin and enter this)
ADMIN_PASSWORD=change-me-to-something-strong

# Resend API key — for sending email notifications on form submissions
# Get a free key at https://resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx

# Email recipient for new-submission notifications
NOTIFICATION_EMAIL=upwarddigitalco@gmail.com
